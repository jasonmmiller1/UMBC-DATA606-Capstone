# Local-first default configuration
# Keep LLM_BACKEND=none for retrieval-only mode.
# Switch LLM_BACKEND to openrouter only after adding a valid API key and a paid-capable model id.
LLM_BACKEND=none

# OpenRouter configuration placeholders only. Do not commit real credentials.
OPENROUTER_MODEL=provider/model-name
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_TOKENS=600
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_RETRY_COUNT=2
OPENROUTER_APP_TITLE=RMF Assistant
OPENROUTER_APP_URL=http://localhost:8501

QDRANT_HOST=localhost
QDRANT_PORT=6333

BM25_INDEX_PATH=data/bm25_index/bm25_index.pkl
CHUNKS_PATH=data/index/chunks.parquet
