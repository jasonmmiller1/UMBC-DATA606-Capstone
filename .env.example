# Default runtime configuration for both local runs and containerized demo deploys.
# Keep LLM_BACKEND=none for retrieval-only mode.
# Switch LLM_BACKEND to openrouter only after adding a valid API key and a paid-capable model id.
APP_ENV=local
PORT=8501
LLM_BACKEND=none

# OpenRouter configuration placeholders only. Do not commit real credentials.
OPENROUTER_MODEL=provider/model-name
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_TOKENS=600
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_RETRY_COUNT=2
OPENROUTER_APP_TITLE=RMF Assistant
OPENROUTER_APP_URL=http://localhost:8501

# Qdrant connection:
# - local host-run defaults: QDRANT_HOST=localhost / QDRANT_PORT=6333
# - local Docker Compose overrides host to qdrant automatically
# - remote deployments can set QDRANT_URL and optional QDRANT_API_KEY instead
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rmf_chunks
QDRANT_TIMEOUT=0.75
QDRANT_STATUS_ENABLED=0

BM25_INDEX_PATH=data/bm25_index/bm25_index.pkl
CHUNKS_PATH=data/index/chunks.parquet

# Container/demo startup controls
PREPARE_LOCAL_INDEXES_ON_START=1
WAIT_FOR_QDRANT_ON_START=1
REQUIRE_QDRANT_COLLECTION=1
STARTUP_QDRANT_TIMEOUT_SECONDS=120

# Optional retrieval tuning overrides
# RERANK_ENABLED=1
# RETRIEVAL_DENSE_K=20
# RETRIEVAL_BM25_K=20
